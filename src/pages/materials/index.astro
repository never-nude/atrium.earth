---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkCard from '../../components/WorkCard.astro';
import { facets, worksForMaterial } from '../../lib/catalog';
import { withBase } from '../../lib/urls';

const groups = facets.materials.map((facet) => ({ ...facet, works: worksForMaterial(facet.label) }));
---

<BaseLayout title="Materials" description="Browse the sculpture collection by material.">
  <section class="page-shell" aria-labelledby="materials-title">
    <p class="eyebrow">Material</p>
    <h1 id="materials-title">Browse by material.</h1>
    <p class="lede">Marble, bronze, limestone, wood, and more.</p>
  </section>

  <section class="section" aria-labelledby="materials-groups">
    <div class="facet-grid" id="materials-groups">
      {groups.map((group) => (
        <a class="facet-card" href={`#${group.value}`}>
          <strong>{group.label}</strong>
          <span>{group.count} works</span>
        </a>
      ))}
    </div>
  </section>

  {groups.map((group) => (
    <section class="section" id={group.value} aria-labelledby={`${group.value}-title`}>
      <div class="section-head">
        <div>
          <p class="eyebrow">{group.count} works</p>
          <h2 id={`${group.value}-title`}>{group.label}</h2>
        </div>
        <a class="text-link" href={withBase(`/museum/?materials=${group.value}`)}>Open in museum</a>
      </div>
      <div class="rail">
        {group.works.slice(0, 8).map((work) => <WorkCard work={work} />)}
      </div>
    </section>
  ))}
</BaseLayout>
